# Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DB_PATH=./chat.db

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Socket.io Configuration
SOCKET_PORT=5000
